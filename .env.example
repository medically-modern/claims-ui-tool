# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit a populated copy of this file.

# Monday.com API token. Get one at:
# https://medicallymodern-force.monday.com → avatar → Developers → My Access Tokens
#
# WARNING: this token will be embedded in the compiled JS bundle (Vite inlines
# VITE_* env vars at build time). On the deployed GitHub Pages site, anyone
# who opens DevTools can read it. While the tool is internal-only (URL
# distributed only to employees) this is acceptable. Rotate the token any
# time you suspect it has leaked, and migrate to Monday OAuth before opening
# the tool to broader distribution.
VITE_MONDAY_API_TOKEN=
